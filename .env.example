# Salin file ini menjadi .env dan sesuaikan nilainya
OUTPUT_DIR=hasil_label6

SIGLIP_MODEL_ID=google/siglip2-base-patch16-224

# Sumber blendshape → AU FACS:
#   mediapipe       (default) = blendshape bawaan MediaPipe FaceLandmarker (gratis, sudah keluar)
#   mp_blendshapes            = model py-feat mp_blendshapes (MLP-Mixer mesh→52 blendshape, standalone
#                               torch; weights 1.8MB auto-download dari HuggingFace). Eksperimen A/B.
BLENDSHAPE_SOURCE=mediapipe

# Faktor padding crop wajah MediaPipe (BlazeFace).
# Nilai relatif terhadap ukuran bounding box deteksi.
# Semakin besar = area crop makin luas (lebih banyak konteks kepala/leher).
# Semakin kecil = crop lebih ketat ke area wajah saja.
# Range yang disarankan: 0.3 (ketat) – 0.8 (longgar). Default: 0.6
FACE_CROP_PADDING=0.60

# Bobot hybrid scoring GLOBAL (dipakai jika per-label tidak diset).
SIGLIP_WEIGHT=0.50
LANDMARK_WEIGHT=0.50

# Bobot per-label — sesuaikan sesuai performa masing-masing emosi.
# Diubah ke keseimbangan penuh (50/50) untuk truly hybrid
BOREDOM_SIGLIP_WEIGHT=0.50
BOREDOM_LANDMARK_WEIGHT=0.50
ENGAGEMENT_SIGLIP_WEIGHT=0.50
ENGAGEMENT_LANDMARK_WEIGHT=0.50
CONFUSION_SIGLIP_WEIGHT=0.50
CONFUSION_LANDMARK_WEIGHT=0.50
FRUSTRATION_SIGLIP_WEIGHT=0.50
FRUSTRATION_LANDMARK_WEIGHT=0.50

# Auto-flag jika frame dengan >1 muka terdeteksi melebihi threshold ini.
# Set ke 16 untuk menonaktifkan.
MULTI_FACE_FRAMES_THRESHOLD=4
